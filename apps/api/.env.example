# ──────────────────────────────────────────────
# VibeSearch API — Environment Variables
# ──────────────────────────────────────────────

# Database (Neon free tier recommended)
DATABASE_URL=postgresql+asyncpg://user:password@host/vibesearch?sslmode=require
DATABASE_URL_SYNC=postgresql://user:password@host/vibesearch?sslmode=require

# CORS — allowed frontend origins (comma separated)
CORS_ORIGINS=http://localhost:3000,https://vibesearch.vercel.app

# FAISS index directory
FAISS_INDEX_PATH=./data/index/scenes.index

# Frame/thumbnail storage
# For MVP: use Cloudinary free tier or local paths
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Auth — must match the frontend Auth.js secret
AUTH_SECRET=your-auth-secret-here

# Server
HOST=0.0.0.0
PORT=8000
ENV=development
